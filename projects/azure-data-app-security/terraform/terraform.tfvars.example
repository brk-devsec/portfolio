# =============================================================
#  terraform.tfvars.example
#  실제 값으로 채운 뒤 terraform.tfvars 로 복사해서 사용하세요.
#  terraform.tfvars 는 .gitignore 처리되어 커밋되지 않습니다.
# =============================================================

prefix   = "team602"
location = "KoreaCentral"
rg_name  = "team602-rg"

admin_username = "azureadmin"

vm_size = "Standard_D2as_v4"

# --- Bastion 관리자 IP (본인 공인 IP로 교체) ---
admin_ip = "203.0.113.10/32"

# --- MariaDB / WordPress (강력한 비밀번호로 교체) ---
mysql_root_password = "<CHANGE_ME>"
mysql_app_user      = "wpuser"
mysql_app_password  = "<CHANGE_ME>"
mysql_database      = "wordpress"

# --- 거버넌스 표준 태그 ---
tags = {
  team                = "team602"
  owner               = "team602"
  project             = "azure-security-lab"
  environment         = "lab"
  data_classification = "internal"
  managed_by          = "terraform"
}

# --- RBAC 대상 Entra ID 사용자/그룹 Object ID로 교체 ---
vm_operator_principal_id       = "<PRINCIPAL_OBJECT_ID>"
monitoring_reader_principal_id = "<PRINCIPAL_OBJECT_ID>"
network_operator_principal_id  = "<PRINCIPAL_OBJECT_ID>"
